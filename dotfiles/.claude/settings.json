{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "LANGFUSE_HOST": "http://192.168.4.43:3050",
    "TRACE_TO_LANGFUSE": "true"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Skill(*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "LS",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Monitor",
      "SendMessage",
      "NotebookEdit",
      "NotebookRead",
      "TaskCreate",
      "TaskUpdate",
      "TaskList",
      "TaskGet",
      "TaskOutput",
      "TaskStop",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ExitWorktree",
      "AskUserQuestion",
      "LSP",
      "TeamCreate",
      "TeamDelete",
      "RemoteTrigger",
      "CronCreate",
      "CronDelete",
      "CronList",
      "Bash(gh issue close:*)",
      "Bash(gh issue comment:*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(rm -rf / *)",
      "Bash(rm -rf ~*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/workflow-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "ext=\"${CLAUDE_FILE##*.}\"; if [ \"$ext\" = \"py\" ]; then ruff check --fix \"$CLAUDE_FILE\" 2>/dev/null && ruff format \"$CLAUDE_FILE\" 2>/dev/null; elif [ \"$ext\" = \"ts\" ] || [ \"$ext\" = \"tsx\" ]; then npx eslint --fix \"$CLAUDE_FILE\" 2>/dev/null; fi",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_FILE\" ]; then grep -nE '(sk-[a-zA-Z0-9]{20,}|AKIA[0-9A-Z]{16}|-----BEGIN (RSA |EC )?PRIVATE KEY|password\\s*=\\s*\"[^\"]+\")' \"$CLAUDE_FILE\" && echo 'WARNING: Possible secret detected in '\"$CLAUDE_FILE\" || true; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"$CLAUDE_FILE\" ]; then lines=$(wc -l < \"$CLAUDE_FILE\"); if [ \"$lines\" -gt 300 ]; then echo \"WARNING: $CLAUDE_FILE is $lines lines (max 300)\"; fi; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "case \"$CLAUDE_FILE\" in */.claude/guardian/*.ts) cd ~/.claude/guardian && npx tsc && echo 'Guardian recompiled' || echo 'Guardian compile FAILED — dist/ is stale' ;; esac",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/guardian/run.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/workflow-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/herdr-agent-state.sh\" session",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "for d in $HOME/.claude/plugins/cache/claude-plugins-official/remember/*/hooks.d/after_save; do [ -d \"$d\" ] && [ ! -f \"$d/60-journey.sh\" ] && cp $HOME/.claude/hooks/60-journey.sh \"$d/60-journey.sh\" && chmod +x \"$d/60-journey.sh\"; done",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud-cache.sh ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": false,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": false,
    "context7@claude-plugins-official": true,
    "data-engineering@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": false,
    "figma@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": true,
    "git-cleanup@trailofbits": true,
    "oh-my-claudecode@omc": true,
    "playwright@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": false,
    "remember@claude-plugins-official": true,
    "rpi@local": false,
    "security-guidance@claude-plugins-official": false,
    "serena@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "zeroize-audit@trailofbits": false
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    },
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "advisorModel": "opus",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "preferredNotifChannel": "ghostty",
  "teammateMode": "tmux",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "model": "opus"
}
